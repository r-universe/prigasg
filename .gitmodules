[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	branch = HEAD
[submodule "bs4Dashkit"]
	path = bs4Dashkit
	url = https://github.com/prigasg/bs4dashkit
[submodule "dragmapr"]
	path = dragmapr
	url = https://github.com/prigasg/dragmapr
[submodule "explodemap"]
	path = explodemap
	url = https://github.com/prigasg/explodemap
[submodule "glasstabs"]
	path = glasstabs
	url = https://github.com/prigasg/glasstabs
[submodule "locatr"]
	path = locatr
	url = https://github.com/prigasg/locatr
[submodule "printtree"]
	path = printtree
	url = https://github.com/prigasg/printtree
[submodule "twbparser"]
	path = twbparser
	url = https://github.com/prigasg/twbparser
